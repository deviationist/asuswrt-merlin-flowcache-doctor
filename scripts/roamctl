#!/bin/sh
# roamctl — control wrapper for the flowcache-doctor detection daemon.
# Provides systemd-like lifecycle on Asuswrt-Merlin: boot start, crash
# watchdog (via cru/cron), manual stop that disarms the watchdog, and a
# persistent on/off policy.
DAEMON=/jffs/scripts/roam-detect.sh
TAG=roam-detect
FLAG=/tmp/roam-detect.disabled           # runtime manual-stop flag (cleared by start/reboot)
POLICY=/jffs/scripts/roam-detect.policy  # persistent policy: "on" (default if absent) or "off"

# busybox on these routers has no pgrep/pkill — use ps+awk
pids() { ps w | grep "[r]oam-detect.sh" | awk '{print $1}'; }
policy() { [ -f "$POLICY" ] && cat "$POLICY" || echo on; }

case "$1" in
  start)    rm -f "$FLAG"; [ -n "$(pids)" ] || "$DAEMON" >/dev/null 2>&1 & ;;
  stop)     touch "$FLAG"; for p in $(pids); do kill "$p"; done
            logger -t "$TAG" "stopped manually (watchdog disarmed until 'roamctl start' or reboot)" ;;
  restart)  for p in $(pids); do kill "$p"; done; sleep 1; rm -f "$FLAG"; "$DAEMON" >/dev/null 2>&1 & ;;
  status)   echo "policy: $(policy)"; ps w | grep "[r]oam-detect.sh" || echo "not running$([ -f $FLAG ] && echo ' (manually stopped)')" ;;
  log)      grep "$TAG" /tmp/syslog.log | tail -30 ;;
  policy)   case "$2" in
              on|off) echo "$2" > "$POLICY"; logger -t "$TAG" "restart policy set to $2"; echo "policy: $2" ;;
              *) echo "policy: $(policy)" ;;
            esac ;;
  boot)     [ "$(policy)" = "on" ] || exit 0
            [ -n "$(pids)" ] || "$DAEMON" >/dev/null 2>&1 & ;;
  watchdog) [ "$(policy)" = "on" ] || exit 0
            [ -f "$FLAG" ] && exit 0
            [ -n "$(pids)" ] || { logger -t "$TAG" "watchdog: daemon not running, restarting"; "$DAEMON" >/dev/null 2>&1 & } ;;
  *)        echo "usage: roamctl start|stop|restart|status|log|watchdog|boot|policy [on|off]" ;;
esac
