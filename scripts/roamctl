#!/bin/sh
# roamctl — control wrapper for the flowcache-doctor detection daemon.
# Provides systemd-like lifecycle on Asuswrt-Merlin: boot start, crash
# watchdog (via cru/cron), manual stop that disarms the watchdog, and a
# persistent on/off policy.
VERSION=0.2.4
DAEMON=/jffs/scripts/roam-detect.sh
EVDAEMON=/jffs/scripts/roam-events.sh    # wlceventd event listener (default-on when the event log exists)
CONF=/jffs/scripts/roam-detect.conf
REPO_RAW="https://raw.githubusercontent.com/deviationist/asuswrt-merlin-flowcache-doctor/main"
UPDATE_TMP=/tmp/roam-detect.update.sh    # transient installer copy for 'update' (RAM)
TAG=roam-detect
FLAG=/tmp/roam-detect.disabled           # runtime manual-stop flag (cleared by start/reboot)
POLICY=/jffs/scripts/roam-detect.policy  # persistent policy: "on" (default if absent) or "off"
FLUSHFLAG=/jffs/scripts/roam-detect.flush # exists => auto-flush enabled (persistent)

# busybox on these routers has no pgrep/pkill. A naive `ps | grep` also
# matches the *calling* SSH session if its command line mentions the daemon
# path (restart would then kill the caller's connection) — so: pidfile first,
# with the daemon's distinctive "{roam-detect.sh}" ps form as orphan fallback.
PIDFILE=/tmp/roam-detect.pid
pids() {
  if [ -f "$PIDFILE" ]; then
    p=$(cat "$PIDFILE")
    grep -q "roam-detect.sh" "/proc/$p/cmdline" 2>/dev/null && { echo "$p"; return; }
  fi
  ps w | grep "{[r]oam-detect.sh}" | awk '{print $1}'
}
epids() {
  if [ -f /tmp/roam-events.pid ]; then
    p=$(cat /tmp/roam-events.pid)
    grep -q "roam-events.sh" "/proc/$p/cmdline" 2>/dev/null && { echo "$p"; return; }
  fi
  ps w | grep "{[r]oam-events.sh}" | awk '{print $1}'
}
policy() { [ -f "$POLICY" ] && cat "$POLICY" || echo on; }
# Event listener: ON by default; disable with EVENT_HEAL=0 in the conf.
# Auto-stands-down when the firmware doesn't provide the wlceventd event log.
events_enabled() { EVENT_HEAL=1; [ -f "$CONF" ] && . "$CONF"; [ "$EVENT_HEAL" != "0" ] && [ -x "$EVDAEMON" ] && [ -f /jffs/wifi_wlc.log ]; }
start_ev() { events_enabled || return 0; [ -n "$(epids)" ] || "$EVDAEMON" >/dev/null 2>&1 & }
stop_ev()  { for p in $(epids); do kill "$p"; done; }

case "$1" in
  start)    rm -f "$FLAG"; [ -n "$(pids)" ] || "$DAEMON" >/dev/null 2>&1 &
            start_ev ;;
  stop)     touch "$FLAG"; for p in $(pids); do kill "$p"; done; stop_ev
            logger -t "$TAG" "stopped manually (watchdog disarmed until 'roamctl start' or reboot)" ;;
  restart)  for p in $(pids); do kill "$p"; done; stop_ev; sleep 1; rm -f "$FLAG"; "$DAEMON" >/dev/null 2>&1 &
            start_ev ;;
  status)   echo "version: $VERSION"
            echo "policy: $(policy)"; echo "autoflush: $([ -f "$FLUSHFLAG" ] && echo on || echo off)"
            p=$(pids)
            if [ -n "$p" ]; then echo "running (pid $p)"; else echo "not running$([ -f $FLAG ] && echo ' (manually stopped)')"; fi
            if events_enabled; then
              ep=$(epids)
              if [ -n "$ep" ]; then echo "event listener: running (pid $ep)"; else echo "event listener: enabled but NOT running"; fi
            else
              echo "event listener: off (EVENT_HEAL=1 in roam-detect.conf to enable)"
            fi ;;
  log)      grep "$TAG" /tmp/syslog.log | tail -30 ;;
  policy)   case "$2" in
              on|off) echo "$2" > "$POLICY"; logger -t "$TAG" "restart policy set to $2"; echo "policy: $2" ;;
              *) echo "policy: $(policy)" ;;
            esac ;;
  flush)    case "$2" in
              on)  touch "$FLUSHFLAG"; logger -t "$TAG" "auto-flush ENABLED (per-MAC, rate-limited)"; echo "autoflush: on" ;;
              off) rm -f "$FLUSHFLAG"; logger -t "$TAG" "auto-flush disabled (log-only)"; echo "autoflush: off" ;;
              *)   echo "autoflush: $([ -f "$FLUSHFLAG" ] && echo on || echo off)" ;;
            esac ;;
  boot)     [ "$(policy)" = "on" ] || exit 0
            [ -n "$(pids)" ] || "$DAEMON" >/dev/null 2>&1 &
            start_ev ;;
  watchdog) [ "$(policy)" = "on" ] || exit 0
            [ -f "$FLAG" ] && exit 0
            [ -n "$(pids)" ] || { logger -t "$TAG" "watchdog: daemon not running, restarting"; "$DAEMON" >/dev/null 2>&1 & }
            if events_enabled && [ -z "$(epids)" ]; then
              logger -t "$TAG" "watchdog: event listener not running, restarting"; "$EVDAEMON" >/dev/null 2>&1 &
            fi ;;
  health)   rc=0
            ok()   { echo "  ok:   $1"; }
            bad()  { echo "  FAIL: $1"; rc=1; }
            note() { echo "  warn: $1"; }
            echo "flowcache-doctor $VERSION health check"
            # --- install integrity ---
            [ "$(nvram get jffs2_scripts)" = "1" ] && ok "JFFS custom scripts enabled" || bad "JFFS custom scripts disabled (nvram jffs2_scripts)"
            for f in "$DAEMON" "$EVDAEMON"; do
              [ -x "$f" ] && ok "present+executable: $f" || bad "missing or not executable: $f"
            done
            SS=/jffs/scripts/services-start
            grep -q "roamctl boot" "$SS" 2>/dev/null && ok "boot hook in services-start" || bad "boot hook missing from services-start"
            grep -q "roam-detect-wd" "$SS" 2>/dev/null && ok "watchdog registration in services-start" || bad "watchdog registration missing from services-start"
            cru l 2>/dev/null | grep -q "roam-detect-wd" && ok "cron watchdog armed" || bad "cron watchdog not registered (cru l)"
            # NB: this busybox has no `command` builtin — probe with `which`
            which fcctl >/dev/null 2>&1 && ok "fcctl available" || bad "fcctl not found — healing impossible on this firmware"
            # --- config + radios ---
            if [ -f "$CONF" ]; then
              sh -n "$CONF" 2>/dev/null && ok "conf parses: $CONF" || bad "conf has syntax errors: $CONF"
            fi
            BSSLIST="wl0.1 wl1.1 wl2.1"; [ -f "$CONF" ] && . "$CONF"
            for b in $BSSLIST; do
              if [ -d "/sys/class/net/$b" ]; then
                [ -d "/sys/class/net/br0/brif/$b" ] && ok "BSS $b exists, member of br0" || note "BSS $b exists but is NOT in br0 — check BSSLIST"
              else
                bad "BSS $b does not exist — set BSSLIST in $CONF (br0 members: $(ls /sys/class/net/br0/brif 2>/dev/null | tr '\n' ' '))"
              fi
            done
            # --- runtime ---
            [ "$(policy)" = "on" ] && ok "policy on" || note "policy off — daemons disabled persistently (roamctl policy on)"
            [ -f "$FLUSHFLAG" ] && ok "auto-flush on" || note "auto-flush off — audit-only mode (roamctl flush on)"
            p=$(pids)
            [ -n "$p" ] && ok "poller running (pid $p)" || bad "poller NOT running"
            if events_enabled; then
              ep=$(epids)
              [ -n "$ep" ] && ok "event listener running (pid $ep)" || bad "event listener enabled but NOT running"
            elif [ "$EVENT_HEAL" = "0" ]; then note "event listener disabled by conf (EVENT_HEAL=0)"
            elif [ ! -f /jffs/wifi_wlc.log ]; then note "event listener standing down: no /jffs/wifi_wlc.log on this firmware (poller covers healing)"
            else note "event listener off"
            fi
            [ -d /tmp/roam-detect ] && ok "state dir present (/tmp/roam-detect)" || note "state dir absent (created on the daemon's first pass)"
            if [ $rc -eq 0 ]; then echo "healthy."; else echo "PROBLEMS FOUND — see FAIL lines above."; fi
            exit $rc ;;
  update)   echo "flowcache-doctor $VERSION — fetching the latest installer from GitHub (main)..."
            # ?cb= busts the raw.githubusercontent.com CDN cache (the query
            # string is part of its cache key; without it, a just-pushed fix
            # can take many minutes to be served)
            curl -fsSL "$REPO_RAW/install.sh?cb=$(date +%s)" -o "$UPDATE_TMP" || { echo "ERROR: download failed — does the router have internet access?"; exit 1; }
            # exec, don't run-and-return: the installer overwrites this very
            # script, and busybox sh reads scripts incrementally — a running
            # script must never keep executing while its file is rewritten.
            # exec replaces this process with the installer (running from RAM),
            # after which /jffs/scripts/roamctl is free to be replaced. The
            # installer preserves the conf and the flush/policy choices, and
            # restarts both daemons.
            exec sh "$UPDATE_TMP" ;;
  uninstall) for p in $(pids); do kill "$p"; done; stop_ev
            cru d roam-detect-wd 2>/dev/null
            SS=/jffs/scripts/services-start
            [ -f "$SS" ] && sed -i '/roamctl boot/d; /roam-detect-wd/d' "$SS"
            rm -f "$DAEMON" "$EVDAEMON" "$POLICY" "$FLAG" "$FLUSHFLAG" "$CONF" /tmp/roam-events.pid "$UPDATE_TMP"
            rm -rf /tmp/roam-detect
            logger -t "$TAG" "uninstalled"
            echo "flowcache-doctor uninstalled."
            rm -f "$0" ;;
  *)        echo "usage: roamctl start|stop|restart|status|health|log|watchdog|boot|policy [on|off]|flush [on|off]|update|uninstall" ;;
esac
